{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(**)",
      "Write(**)",
      "Edit(**)",
      "Glob(**)",
      "Grep(**)",
      "NotebookEdit(**)",
      "WebFetch(domain:*)",
      "WebSearch"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.local)",
      "Read(.env.development)",
      "Read(.env.development.local)",
      "Read(.env.production)",
      "Read(.env.production.local)",
      "Read(.env.staging)",
      "Read(.env.staging.local)",
      "Read(.env.test)",
      "Read(.env.test.local)",
      "Read(**/secrets/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(~/.aws/**)",
      "Read(~/.ssh/**)",
      "Read(~/.doppler/**)",
      "Read(~/.npmrc)",
      "Read(~/.netrc)",

      "Bash(sudo *)",
      "Bash(sudo)",
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(rm -Rf *)",
      "Bash(rm -fR *)",
      "Bash(git reset --hard*)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git push --delete*)",
      "Bash(git branch -D*)",
      "Bash(git clean -f*)",
      "Bash(git filter-branch*)",
      "Bash(gh repo delete*)",
      "Bash(gh repo edit --visibility public*)",
      "Bash(gh repo create --public*)",

      "Bash(env)",
      "Bash(printenv)",
      "Bash(printenv *)",
      "Bash(doppler secrets download*)",
      "Bash(doppler secrets get*)",
      "Bash(doppler configure*)",
      "Bash(doppler login*)",

      "Bash(apt-get install*)",
      "Bash(apt-get remove*)",
      "Bash(apt install*)",
      "Bash(apt remove*)",
      "Bash(dpkg -i*)",
      "Bash(brew install*)",
      "Bash(brew uninstall*)",
      "Bash(snap install*)",
      "Bash(yum install*)",
      "Bash(dnf install*)",
      "Bash(npm install -g*)",
      "Bash(npm i -g*)",
      "Bash(npm install --global*)",
      "Bash(yarn global add*)",
      "Bash(pnpm add -g*)",
      "Bash(pip install --user*)",
      "Bash(pip3 install --user*)",
      "Bash(pipx install*)",
      "Bash(nvm install*)",
      "Bash(fnm install*)",
      "Bash(pyenv install*)",
      "Bash(asdf install*)",
      "Bash(rustup*)",
      "Bash(rvm install*)",
      "Bash(volta install*)"
    ]
  },

  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [{ "type": "command", "command": "$HOME/agent-runner/runners/guard-hook.sh" }]
      }
    ]
  }
}
