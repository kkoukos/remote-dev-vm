{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(**)",
      "Write(**)",
      "Edit(**)",
      "Glob(**)",
      "Grep(**)",
      "NotebookEdit(**)",
      "WebFetch(domain:*)",
      "WebSearch"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.local)",
      "Read(.env.development)",
      "Read(.env.development.local)",
      "Read(.env.production)",
      "Read(.env.production.local)",
      "Read(.env.staging)",
      "Read(.env.staging.local)",
      "Read(.env.test)",
      "Read(.env.test.local)",
      "Read(**/secrets/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(~/.aws/**)",
      "Read(~/.ssh/**)",
      "Read(~/.doppler/**)",
      "Read(~/.npmrc)",
      "Read(~/.netrc)",

      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(rm -Rf *)",
      "Bash(rm -fR *)",
      "Bash(git reset --hard*)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git push --delete*)",
      "Bash(git branch -D*)",
      "Bash(git clean -f*)",
      "Bash(git filter-branch*)",
      "Bash(gh repo delete*)",
      "Bash(gh repo edit --visibility public*)",

      "Bash(env)",
      "Bash(printenv)",
      "Bash(printenv *)",
      "Bash(doppler secrets download*)",
      "Bash(doppler secrets get*)",
      "Bash(doppler configure*)",
      "Bash(doppler login*)"
    ]
  }
}
